function login(){

let name = prompt("Введите ваше имя");

if(!name) return;

localStorage.setItem(
"muboriz_username",
name
);

alert(
"Добро пожаловать, " + name + "!"
);

}

function logout(){

localStorage.removeItem(
"muboriz_username"
);

alert("Вы вышли из аккаунта");

}

function getUser(){

return localStorage.getItem(
"muboriz_username"
) || "Гость";

}

function isLoggedIn(){

return localStorage.getItem(
"muboriz_username"
) !== null;

}
