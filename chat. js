function sendMessage() {

const input = document.getElementById("userInput");
const messages = document.getElementById("messages");

const text = input.value.trim();

if(text === "") return;

messages.innerHTML += `
<div class="user-message">
👤 ${text}
</div>
`;

let answer = "";

const msg = text.toLowerCase();

if(msg.includes("привет")){
answer = "Привет! Я Muboriz AI.";
}

else if(msg.includes("контакт")){
answer = "Наш босс: Мубориз. Телефон: +992 011 900 303";
}

else if(msg.includes("помощь")){
answer = "Я могу отвечать на простые вопросы.";
}

else if(msg.includes("сайт")){
answer = "Это сайт Muboriz AI.";
}

else if(msg.includes("кто тебя создал")){
answer = "Меня создал Мубориз.";
}

else if(msg.includes("как дела")){
answer = "Отлично!";
}

else{

answer = "Я пока изучаю этот вопрос.";

}

setTimeout(() => {

messages.innerHTML += `
<div class="bot-message">
🤖 ${answer}
</div>
`;

messages.scrollTop = messages.scrollHeight;

},500);

input.value = "";

}

document.addEventListener("keypress",function(e){

if(e.key==="Enter"){

sendMessage();

}

});
