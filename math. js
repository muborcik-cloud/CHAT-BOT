function solveMath(example){

try{

const result = Function(
'"use strict"; return (' + example + ')'
)();

if(isNaN(result)){
return null;
}

return result;

}catch{

return null;

}

}

function checkMath(text){

const pattern =
/^[0-9+\-*/(). ]+$/;

if(pattern.test(text)){

const answer =
solveMath(text);

if(answer !== null){

return "Ответ: " + answer;

}

}

return null;

}
