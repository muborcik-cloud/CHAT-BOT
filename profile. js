let profile = {

name:"Гость",
messages:0,
created:new Date().toLocaleDateString()

};

function loadProfile(){

const data =
localStorage.getItem("muboriz_profile");

if(data){

profile = JSON.parse(data);

}

}

function saveProfile(){

localStorage.setItem(
"muboriz_profile",
JSON.stringify(profile)
);

}

function setUser(name){

profile.name = name;

saveProfile();

}

function addMessage(){

profile.messages++;

saveProfile();

}

function getProfile(){

return profile;

}

loadProfile();
